LIBRARY d3d9
EXPORTS
; Legacy Direct3D 9 export ordinals seen on older Windows d3d9.dll builds.
; These NONAME aliases keep old games/wrappers that import d3d9 by ordinal working.
Direct3DShaderValidatorCreate9_ord1=Direct3DShaderValidatorCreate9_stub @1 NONAME
PSGPError_ord2=PSGPError_stub @2 NONAME
PSGPSampleTexture_ord3=PSGPSampleTexture_stub @3 NONAME
D3DPERF_BeginEvent_ord4=D3DPERF_BeginEvent_stub @4 NONAME
D3DPERF_EndEvent_ord5=D3DPERF_EndEvent_stub @5 NONAME
D3DPERF_GetStatus_ord6=D3DPERF_GetStatus_stub @6 NONAME
D3DPERF_QueryRepeatFrame_ord7=D3DPERF_QueryRepeatFrame_stub @7 NONAME
D3DPERF_SetMarker_ord8=D3DPERF_SetMarker_stub @8 NONAME
D3DPERF_SetOptions_ord9=D3DPERF_SetOptions_stub @9 NONAME
D3DPERF_SetRegion_ord10=D3DPERF_SetRegion_stub @10 NONAME
DebugSetLevel_ord11=DebugSetLevel_stub @11 NONAME
DebugSetMute_ord12=DebugSetMute_stub @12 NONAME
Direct3DCreate9_ord13=Direct3DCreate9_proxy @13 NONAME
Direct3DCreate9Ex_ord14=Direct3DCreate9Ex_proxy @14 NONAME

; Current Windows D3D9 export ordinal range, including D3D9On12 additions.
Ordinal16=Ordinal16_stub @16 NONAME
Ordinal17=Ordinal17_stub @17 NONAME
Ordinal18=Ordinal18_stub @18 NONAME
Ordinal19=Ordinal19_stub @19 NONAME
Direct3DCreate9On12=Direct3DCreate9On12_stub @20
Direct3DCreate9On12Ex=Direct3DCreate9On12Ex_stub @21
Ordinal22=Ordinal22_stub @22 NONAME
Ordinal23=Ordinal23_stub @23 NONAME
Direct3DShaderValidatorCreate9=Direct3DShaderValidatorCreate9_stub @24
PSGPError=PSGPError_stub @25
PSGPSampleTexture=PSGPSampleTexture_stub @26
D3DPERF_BeginEvent=D3DPERF_BeginEvent_stub @27
D3DPERF_EndEvent=D3DPERF_EndEvent_stub @28
D3DPERF_GetStatus=D3DPERF_GetStatus_stub @29
D3DPERF_QueryRepeatFrame=D3DPERF_QueryRepeatFrame_stub @30
D3DPERF_SetMarker=D3DPERF_SetMarker_stub @31
D3DPERF_SetOptions=D3DPERF_SetOptions_stub @32
D3DPERF_SetRegion=D3DPERF_SetRegion_stub @33
DebugSetLevel=DebugSetLevel_stub @34
DebugSetMute=DebugSetMute_stub @35
Direct3D9EnableMaximizedWindowedModeShim=Direct3D9EnableMaximizedWindowedModeShim_stub @36
Direct3DCreate9=Direct3DCreate9_proxy @37
Direct3DCreate9Ex=Direct3DCreate9Ex_proxy @38
